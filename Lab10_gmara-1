"""
Program Name: Word Counter
Author: Gnalen Mara
Description: This program displays four text files and lets the user choose one and analyze it by
             counting the number of times each word appears, then outputs the results in alphabetical order.
Starter code: none
Date: 03/27/2026
"""

from pathlib import Path
import string


class WordAnalyzer:
    def __init__(self, filepath):
        self.__path = Path(filepath)
        self.__frequencies = {}

    def process_file(self):
        try:
            if not self.__path.exists():
                return False

            remove_punct = str.maketrans("", "", string.punctuation)

            with self.__path.open("r", encoding="utf-8") as file:
                for line in file:
                    clean_line = line.lower().translate(remove_punct)
                    words = clean_line.split()

                    for word in words:
                        if word not in self.__frequencies:
                            self.__frequencies[word] = 1
                        else:
                            self.__frequencies[word] += 1

            return True
        except FileNotFoundError:
            return False

    def print_report(self):
        print()
        for word in sorted(self.__frequencies.keys()):
            print(f"{word:<10} :: {self.__frequencies[word]}")
        print()
def main():
    print("Word Counter ---")

    # Build the folder path where this script lives
    base_folder = Path(__file__).parent

    # Dictionary of menu options mapped to file paths
    file_options = {
        "1": base_folder / "princess_mars.txt",
        "2": base_folder / "Tarzan.txt",
        "3": base_folder / "treasure_island.txt",
        "4": base_folder / "monte_cristo.txt"
    }

    # Loop until the user chooses to exit
    while True:
        print("\nPlease choose a file to analyze:")
        print("1. Princess of Mars")
        print("2. Tarzan")
        print("3. Treasure Island")
        print("4. The Count of Monte Cristo")
        print("5. Exit\n")

        choice = input("Enter your choice (1-5): ").strip()

        # Exit option
        if choice == "5":
            print("\nGoodbye!")
            break

        # Validate input
        if choice not in file_options:
            print("\nInvalid choice. Please select a number from 1 to 5.")
            input("Press Enter to return to the menu...")
            continue

        # Process the selected file
        selected_file = file_options[choice]
        print(f"\nProcessing '{selected_file.name}'...\n")

        analyzer = WordAnalyzer(selected_file)
        success = analyzer.process_file()

        if success:
            analyzer.print_report()
        else:
            print("Error: Could not read the file.")

        input("Press Enter to return to the menu...")


if __name__ == "__main__":
    main()